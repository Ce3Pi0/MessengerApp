{
  "api": "test",
  "version": "1.0.0",
  "contact": {
    "email": "hristijannikolovski16@gmail.com"
  },
  "syntax": "/api/v<version number>/<endpoint>/<route>/<params>",
  "endpoints": {
    "server": {
      "routes": {
        "status": {
          "methods": "GET",
          "required": null
        }
      }
    },
    "auth": {
      "routes": {
        "google": {
          "methods": "GET",
          "required": null,
          "routes": {
            "success": {
              "methods": "GET",
              "required": {
                "cookies": {
                  "accessToken": "string",
                  "refreshToken": "string"
                }
              }
            }
          }
        },
        "register": {
          "methods": "POST",
          "required": {
            "body": {
              "name": "string",
              "email": "string",
              "provider": "string",
              "password": "string",
              "confirmPassword": "string",
              "avatar": "string"
            }
          }
        },
        "login": {
          "methods": "POST",
          "required": {
            "body": { "email": "string", "password": "string" }
          }
        },
        "logout": {
          "methods": "POST",
          "required": {
            "cookies": { "accessToken": "string", "refreshToken": "string" }
          }
        },
        "verify/:token": {
          "methods": "GET",
          "required": null
        },
        "resend-verification": {
          "methods": "POST",
          "required": {
            "body": { "email": "string" }
          }
        },
        "change-password": {
          "methods": "PUT",
          "required": {
            "body": {
              "currentPassword": "string",
              "newPassword": "string",
              "confirmNewPassword": "string"
            },
            "cookies": {
              "accessToken": "string"
            }
          }
        },
        "send-forgot-password": {
          "methods": "POST",
          "required": {
            "body": {
              "email": "string"
            }
          }
        },
        "forgot-password/:token": {
          "methods": "GET",
          "required": null
        },
        "update-forgotten-password/:token": {
          "methods": "POST",
          "required": {
            "body": {
              "email": "string",
              "newPassword": "string",
              "confirmNewPassword": "string"
            }
          }
        },
        "link-account": {
          "methods": "GET",
          "required": {
            "cookies": {
              "accessToken": "string"
            }
          }
        },
        "set-password": {
          "methods": "POST",
          "required": {
            "body": {
              "password": "string",
              "confirmPassword": "string"
            },
            "cookies": {
              "accessToken": "string"
            }
          }
        },
        "enable2fa": {
          "methods": "GET",
          "required": {
            "cookies": {
              "accessToken": "string"
            }
          }
        },
        "verify2fa": {
          "methods": "POST",
          "required": {
            "body": {
              "otp": "string"
            },
            "cookies": {
              "mfaToken": "string"
            }
          }
        },
        "disable2fa": {
          "methods": "PUT",
          "required": {
            "cookies": {
              "accessToken": "string"
            }
          }
        },
        "status": {
          "methods": "GET",
          "required": {
            "cookies": {
              "accessToken": "string"
            }
          }
        },
        "refresh": {
          "methods": "PUT",
          "required": {
            "cookies": {
              "refreshToken": "string"
            }
          }
        }
      }
    },
    "chat": {
      "routes": {
        "create": {
          "methods": "post",
          "required": {
            "body": {
              "participantId": "string | null",
              "participants": "string[]",
              "isGroup": "boolean",
              "groupName": "string | null"
            }
          }
        },
        "all": {
          "methods": "GET",
          "required": null,
          "query": {
            "cursor": "string"
          }
        },
        ":id": {
          "methods": "GET",
          "required": null,
          "query": {
            "cursor": "string"
          }
        },
        "delete/:id": {
          "methods": "DELETE",
          "required": null
        },
        "remove-user": {
          "methods": "DELETE",
          "required": {
            "body": {
              "userToRemoveId": "string",
              "chatId": "string"
            }
          }
        }
      },
      "required": {
        "cookies": {
          "accessToken": "string",
          "refreshToken": "string"
        }
      }
    },
    "users": {
      "routes": {
        "all": {
          "methods": "GET",
          "required": null,
          "query": {
            "cursor": "string"
          },
          ":id": {
            "methods": "GET",
            "required": null
          },
          "update": {
            "methods": "PUT",
            "required": {
              "body": {
                "name": "string | null",
                "avatar": "string | null"
              }
            }
          },
          "delete": {
            "methods": "POST",
            "required": {
              "cookies": {
                "accessToken": "string"
              }
            }
          }
        },
        ":id": {
          "methods": "GET",
          "required": null
        },
        "update": {
          "methods": "PUT",
          "required": {
            "body": {
              "name": "string | null",
              "avatar": "string | null"
            }
          }
        },
        "delete": {
          "methods": "DELETE",
          "required": null
        }
      },
      "required": {
        "cookies": {
          "accessToken": "string",
          "refreshToken": "string"
        }
      }
    },
    "messages": {
      "routes": {
        "send": {
          "methods": "POST",
          "required": {
            "body": {
              "chatId": "string",
              "content": "string",
              "image": "string",
              "replyToId": "string"
            }
          }
        },
        "edit": {
          "methods": "PUT",
          "required": {
            "body": {
              "chatId": "string",
              "messageId": "string",
              "content": "string"
            }
          }
        },
        "delete": {
          "methods": "DELETE",
          "required": {
            "body": {
              "chatId": "string",
              "messageId": "string"
            }
          }
        }
      },
      "required": {
        "cookies": {
          "accessToken": "string",
          "refreshToken": "string"
        }
      }
    },
    "reactions": {
      "routes": {
        "send": {
          "methods": "POST",
          "required": {
            "body": {
              "chatId": "string",
              "messageId": "string",
              "emoji": "string"
            }
          }
        },
        "delete": {
          "methods": "DELETE",
          "required": {
            "body": {
              "chatId": "string",
              "messageId": "string",
              "reactionId": "string"
            }
          }
        }
      },
      "required": {
        "cookies": {
          "accessToken": "string",
          "refreshToken": "string"
        }
      }
    }
  }
}
